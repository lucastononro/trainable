      "fontSize": 11,
      "fontFamily": 1,
      "text": "1. get_image() \u2014 Modal image\n   (pandas, sklearn, xgboost, torch\u2026)\n2. prepend _SDK_PREAMBLE\n   (trainable.log, configure_dashboard)\n3. Sandbox.create.aio(app, image,\n   volumes={/data: trainable-data})\n4. stream stdout chunks\n5. return {stdout, stderr, returncode}\ntimeout: 600s",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. get_image() \u2014 Modal image\n   (pandas, sklearn, xgboost, torch\u2026)\n2. prepend _SDK_PREAMBLE\n   (trainable.log, configure_dashboard)\n3. Sandbox.create.aio(app, image,\n   volumes={/data: trainable-data})\n4. stream stdout chunks\n5. return {stdout, stderr, returncode}\ntimeout: 600s",
      "autoResize": true,
      "lineHeight": 1.25
