      "fontFamily": 1,
      "text": "GET /api/sessions/{id}/stream\n\nasync def event_generator():\n  q = broadcaster.subscribe(sid)\n  yield SSE heartbeat\n  while True:\n    ev = await q.get()\n    yield 'event:X\\ndata:\u2026\\n\\n'\n\nStreamingResponse(\n  text/event-stream)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET /api/sessions/{id}/stream\n\nasync def event_generator():\n  q = broadcaster.subscribe(sid)\n  yield SSE heartbeat\n  while True:\n    ev = await q.get()\n    yield 'event:X\\ndata:\u2026\\n\\n'\n\nStreamingResponse(\n  text/event-stream)",
      "autoResize": true,
      "lineHeight": 1.25
    },
