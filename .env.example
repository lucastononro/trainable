# ============================================================
# Trainable — Environment Configuration
# ============================================================
# Copy this file to `.env` (in this same directory — repo root)
# and fill in the values you need. docker-compose loads it via
# `env_file: .env`, so values land in the backend container.
#
# You only need ONE auth method per provider. Mix and match — set
# the Claude OAuth token + an OpenAI API key + Modal credentials,
# for example.
# ============================================================


# ============================================================
# Sandbox compute (Modal) — REQUIRED for any agent that runs code
# ============================================================
# Modal powers `execute_code` (the data-science sandbox). Without
# these the agent can still chat but can't run notebooks/scripts.
# Get them from https://modal.com/settings/tokens — click
# "New Token" and copy both halves.
MODAL_TOKEN_ID=ak-xxxxxxxxxxxxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# LLM provider auth — pick at least one
# ============================================================
# Anthropic supports two auth modes: a personal-account OAuth
# token (free with your Claude.ai subscription) and a pay-as-you-
# go API key. OpenAI and Gemini are API-key only here today —
# the file-based CLI OAuth flows (Codex CLI, Gemini CLI) require
# directory mounts that are not wired up yet.
#
# Resolution order for Anthropic: OAuth token first, then API key.

# ---- Anthropic / Claude ------------------------------------
# OAuth (preferred for local dev — uses your Claude.ai subscription
# for usage that would otherwise hit the API). Generated by running
# `claude` (the Claude Code CLI) and signing in; the token lives at
# ~/.claude/<...>.json. The `trainable init` wizard pulls it out
# and writes it here. To get one manually:
#   claude              # open the CLI
#   /login              # complete browser sign-in
# Then copy the OAuth token into:
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxx
#
# API key (required for production, fallback for local). Get from
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# ---- OpenAI / GPT ------------------------------------------
# API key. Get from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# ---- Google / Gemini ---------------------------------------
# API key. Get from https://aistudio.google.com/app/apikey
# Either name works; GEMINI_API_KEY wins if both are set.
# GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxx
# GOOGLE_API_KEY=AIzaSy-xxxxxxxxxxxx


# ============================================================
# Optional — model + agent tuning
# ============================================================
# Default model when an agent's YAML doesn't specify one.
# CLAUDE_MODEL=claude-sonnet-4-6

# Hard ceilings on agent runs.
# AGENT_MAX_TURNS=30
# AGENT_TIMEOUT_SECONDS=1800

# Per-cell sandbox execution timeout, in seconds.
# SANDBOX_TIMEOUT=600

# Backend log level: DEBUG | INFO | WARNING | ERROR.
# LOG_LEVEL=INFO

# When the host's port 8000 is taken (e.g. another dev server),
# remap the backend without changing the container side.
# BACKEND_PORT=8001


# ============================================================
# Optional — observability
# ============================================================
# OpenTelemetry. Dev defaults to the Jaeger sidecar baked into
# docker-compose.yml; only set these to ship traces elsewhere.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_TRACES_SAMPLER_RATIO=1.0

# Sentry — error reporting. Leave blank to disable.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=local


# ============================================================
# Advanced — overridden by docker-compose.prod.yml
# ============================================================
# Don't set these unless you're running outside docker-compose.
# DATABASE_URL=postgresql+asyncpg://trainable:trainable@postgres:5432/trainable
# S3_ENDPOINT=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
