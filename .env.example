# ============================================================
# Trainable — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the required values.
# Everything else is pre-configured by docker-compose.

# === Required ===

# Anthropic API key (powers the AI agent)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Modal credentials (sandboxed code execution)
# Get these from https://modal.com/settings
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# === Optional ===

# Claude model and agent settings
# CLAUDE_MODEL=claude-opus-4-6
# AGENT_MAX_TURNS=30
# AGENT_TIMEOUT_SECONDS=1800
# SANDBOX_TIMEOUT=600

# Logging
# LOG_LEVEL=INFO

# === Advanced (rarely needed) ===
# These are set automatically by docker-compose.prod.yml.
# Only override for custom deployments.

# DATABASE_URL=postgresql+asyncpg://trainable:trainable@postgres:5432/trainable
# S3_ENDPOINT=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
